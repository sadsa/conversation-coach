NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ASSEMBLYAI_API_KEY=
ASSEMBLYAI_WEBHOOK_SECRET=
# Public URL of this app (required for AssemblyAI webhooks). On Vercel you can set APP_URL=https://your-project.vercel.app or it uses VERCEL_URL. For local dev use a tunnel (e.g. ngrok) and set APP_URL to the tunnel URL.
APP_URL=

ANTHROPIC_API_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID contact URI sent to push services (e.g. mailto:you@yourdomain.com)
VAPID_CONTACT=

# Public email shown on /access-denied so locked-out users can request access.
NEXT_PUBLIC_OWNER_EMAIL=

# NEXT_PUBLIC_BUILD_DATE is injected automatically at build time via next.config.mjs — do not set here.
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA is set automatically by Vercel on each deploy — do not set here.
